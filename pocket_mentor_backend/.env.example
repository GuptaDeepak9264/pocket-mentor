APP_NAME=Pocket Mentor
APP_VERSION=1.0.0
DEBUG=true

# Database
DATABASE_URL=sqlite+aiosqlite:///./pocket_mentor.db

# JWT
SECRET_KEY=change-this-to-a-long-random-secret-key-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=30

# File Upload
MAX_UPLOAD_SIZE_MB=20
UPLOAD_DIR=./uploads

# Redis (for Celery workers - optional in MVP)
REDIS_URL=redis://localhost:6379/0

# S3 (optional - leave blank to use local storage)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_BUCKET_NAME=
AWS_REGION=us-east-1

# AI (optional - leave blank to use rules-based generation)
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
